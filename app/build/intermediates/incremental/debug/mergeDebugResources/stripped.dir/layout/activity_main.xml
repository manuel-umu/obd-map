<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout placeholder de la Fase 0.
    El FrameLayout raíz pasará a contener el MapView en la Fase 1; los textos
    centrales se reemplazarán por el mapa y los gauges OBD2 en fases posteriores.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- Texto central provisional para confirmar visualmente que la app arranca. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_title"
            android:textColor="@color/text_primary"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/placeholder_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

    </LinearLayout>

    <!--
        Botón de acceso de emergencia. Se mantiene visible siempre (esquina inferior
        derecha) para que el usuario pueda salir del launcher si algo va mal.
    -->
    <Button
        android:id="@+id/emergencyAccessButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:background="@color/emergency_button"
        android:minHeight="56dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="@string/emergency_access_button"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

</FrameLayout>
