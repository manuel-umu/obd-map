<?xml version="1.0" encoding="utf-8"?>
<!--
    Pantalla de debug OBD2 — Fase 3.
    Muestra telemetría básica (RPM, velocidad, carga) y los nuevos datos
    de consumo diésel (acelerador, temperaturas, MAP, fuel rate, consumo instantáneo/medio).
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Barra de título con botón atrás -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/debugBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:background="@color/primary_dark"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/debug_back_button"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/debug_title"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="@color/surface_dark" />

        <!-- ================================================================ -->
        <!-- BLOQUE: Telemetría básica -->
        <!-- ================================================================ -->

        <!-- Fila RPM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_rpm_label"
                android:textColor="@color/text_secondary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/debugRpmValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Fila Velocidad -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_speed_label"
                android:textColor="@color/text_secondary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/debugSpeedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_speed_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Fila Carga del motor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_load_label"
                android:textColor="@color/text_secondary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/debugLoadValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_load_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Fila Acelerador -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_throttle_label"
                android:textColor="@color/text_secondary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/debugThrottleValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_throttle_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/surface_dark" />

        <!-- ================================================================ -->
        <!-- BLOQUE: Temperaturas y MAP -->
        <!-- ================================================================ -->

        <!-- Fila Temperatura refrigerante -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_coolant_label"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/debugCoolantValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_coolant_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Fila Temperatura admisión (IAT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_iat_label"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/debugIatValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_iat_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Fila MAP (presión colector) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_map_label"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/debugMapValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_map_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/surface_dark" />

        <!-- ================================================================ -->
        <!-- BLOQUE: Consumo -->
        <!-- ================================================================ -->

        <!-- Fila caudal 015E (solo si soportado) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_fuelrate_label"
                android:textColor="@color/text_secondary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/debugFuelRateValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_fuelrate_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Fila método de consumo activo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_fuel_method_label"
                android:textColor="@color/text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/debugFuelMethodValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/debug_fuel_method_none"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Fila consumo instantáneo L/h -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_instant_lh_label"
                android:textColor="@color/text_secondary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/debugInstantLhValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_instant_lh_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Fila consumo instantáneo L/100km -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_instant_l100km_label"
                android:textColor="@color/text_secondary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/debugInstantL100kmValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_instant_l100km_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Fila consumo medio L/100km -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_average_l100km_label"
                android:textColor="@color/text_secondary"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/debugAverageL100kmValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/debug_no_data"
                android:textColor="@color/accent"
                android:textSize="32sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_gravity="bottom"
                android:text="@string/debug_average_l100km_unit"
                android:textColor="@color/text_secondary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Botón resetear consumo medio -->
        <Button
            android:id="@+id/debugResetAvgButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/primary_dark"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/debug_reset_avg_button"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <!-- Separador -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="@color/surface_dark" />

        <!-- ================================================================ -->
        <!-- BLOQUE: Estado de conexión y timestamp -->
        <!-- ================================================================ -->

        <!-- Estado de conexión -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/debug_state_label"
                android:textColor="@color/text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/debugStateValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/obd_state_connecting"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Timestamp de la última lectura -->
        <TextView
            android:id="@+id/debugLastReading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/debug_no_reading_yet"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

    </LinearLayout>
</ScrollView>
