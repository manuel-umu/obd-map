<?xml version="1.0" encoding="utf-8"?>
<!--
    Pantalla de debug OBD2 (Bloque C). Diseño deliberadamente crudo:
    valores en bruto sin conversión, tipografía grande para leer de un vistazo.
    El formateo en unidades reales llega en la Fase 3.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Barra de título con botón atrás -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        android:orientation="horizontal"
        android:padding="8dp">

        <Button
            android:id="@+id/debugBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:background="@color/primary_dark"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/debug_back_button"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="@string/debug_title"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Separador visual -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="@color/surface_dark" />

    <!-- Fila RPM -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/debug_rpm_label"
            android:textColor="@color/text_secondary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/debugRpmValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_no_data"
            android:textColor="@color/accent"
            android:textSize="32sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Fila Velocidad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/debug_speed_label"
            android:textColor="@color/text_secondary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/debugSpeedValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_no_data"
            android:textColor="@color/accent"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_gravity="bottom"
            android:text="@string/debug_speed_unit"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Fila Carga del motor -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/debug_load_label"
            android:textColor="@color/text_secondary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/debugLoadValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="@string/debug_no_data"
            android:textColor="@color/accent"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_gravity="bottom"
            android:text="@string/debug_load_unit"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:background="@color/surface_dark" />

    <!-- Estado de conexión -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/debug_state_label"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/debugStateValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/obd_state_connecting"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />
    </LinearLayout>

    <!-- Timestamp de la última lectura -->
    <TextView
        android:id="@+id/debugLastReading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/debug_no_reading_yet"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

</LinearLayout>
