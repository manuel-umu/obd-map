<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout principal del launcher. Estructura por capas (FrameLayout):
        1. MapView de VTM (OpenGL ES 2.0) ocupando todo el fondo.
        2. Overlay con texto de estado (esquina superior izquierda).
        3. Botón "Recentrar" (esquina inferior izquierda, oculto hasta pan manual).
        4. Botón de emergencia hacia Ajustes (esquina inferior derecha, siempre visible).
    El orden de los hijos en XML es importante: el último se dibuja por encima.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- VTM MapView: renderizado vectorial sobre GLES 2.0 (compatible Mali-450).
         Lee los mismos archivos .map de OSM que usaba Mapsforge. -->
    <org.oscim.android.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        Columna de overlays superior izquierda: primero el HUD de consumo y
        luego el texto de estado del GPS/mapa. El LinearLayout vertical los
        apila sin que se solapen.
        El layout_margin es el mismo 16dp que tenía el statusText para mantener
        el margen visual original.
    -->
    <LinearLayout
        android:id="@+id/topStartOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:orientation="vertical">

        <!--
            Contenedor del HUD de consumo. Empieza GONE si no hay MAC
            configurada; MainActivity lo hace VISIBLE al hacer bind al servicio.
            El fondo semitransparente va aquí para que el IndicatorView no
            necesite pintarlo él mismo (la View no pinta fondo propio).
        -->
        <FrameLayout
            android:id="@+id/hudContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="#CC101418"
            android:padding="8dp"
            android:visibility="gone">

            <obdmap.launcher.ui.IndicatorView
                android:id="@+id/hudFuelIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:label="@string/hud_fuel_label"
                app:unit="@string/hud_fuel_unit_l100km" />

        </FrameLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:padding="10dp"
            android:text="@string/status_initializing"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

    </LinearLayout>

    <Button
        android:id="@+id/recenterButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="@color/primary"
        android:minHeight="56dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="@string/recenter_button"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/emergencyAccessButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:background="@color/emergency_button"
        android:minHeight="56dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="@string/emergency_access_button"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

    <!-- Contenedor inferior central: "Ajustes OBD" y "Debug OBD" en fila horizontal.
         Usando LinearLayout para garantizar separación real en cualquier densidad/DPI.
         Los márgenes sueltos en FrameLayout no funcionan como desplazamiento cuando
         ambos botones comparten el mismo gravity, de ahí el solapamiento en hardware. -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <!-- "Ajustes OBD" en azul primario para que destaque: es la acción
             que el usuario necesita para emparejar el ELM327. -->
        <Button
            android:id="@+id/openSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="@color/primary"
            android:minHeight="56dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/open_app_settings_button"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <!-- "Debug OBD" con fondo surface_dark, menos prominente que Ajustes. -->
        <Button
            android:id="@+id/openObdDebugButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/surface_dark"
            android:minHeight="56dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/open_obd_debug_button"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <!-- Botón para fijar el destino de ruta (Fase 4, paso 4.3). -->
        <Button
            android:id="@+id/openDestinationButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:background="@color/primary"
            android:minHeight="56dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:text="@string/open_destination_button"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

    </LinearLayout>

</FrameLayout>
