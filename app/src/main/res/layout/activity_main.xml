<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout principal del launcher. Estructura por capas (FrameLayout):
        1. MapView de VTM (OpenGL ES 2.0) ocupando todo el fondo.
        2. Overlay con texto de estado (esquina superior izquierda).
        3. Botón "Recentrar" (esquina inferior izquierda, oculto hasta pan manual).
        4. Botón de emergencia hacia Ajustes (esquina inferior derecha, siempre visible).
    El orden de los hijos en XML es importante: el último se dibuja por encima.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- VTM MapView: renderizado vectorial sobre GLES 2.0 (compatible Mali-450).
         Lee los mismos archivos .map de OSM que usaba Mapsforge. -->
    <org.oscim.android.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        Panel de navegación superior (HUD de maniobra).
        Solo visible cuando hay ruta activa y próxima maniobra.
        Diseñado para ser legible a distancia en el coche (fuente grande, iconos grandes).
    -->
    <LinearLayout
        android:id="@+id/navManeuverPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:background="#CC101418"
        android:gravity="center_vertical"
        android:minHeight="80dp"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <!-- Icono de la maniobra -->
        <ImageView
            android:id="@+id/navManeuverIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@string/nav_maneuver_icon_desc"
            android:src="@drawable/ic_maneuver_straight"
            android:tint="#FFFFFFFF" />

        <!-- Distancia + nombre de calle en columna vertical -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/navManeuverDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFFFF"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/navManeuverStreet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#FFB0B0B0"
                android:textSize="18sp" />

        </LinearLayout>

    </LinearLayout>

    <!--
        Columna de overlays superior izquierda: primero el HUD de consumo y
        luego el texto de estado del GPS/mapa. El LinearLayout vertical los
        apila sin que se solapen.
        El layout_margin es el mismo 16dp que tenía el statusText para mantener
        el margen visual original.
    -->
    <LinearLayout
        android:id="@+id/topStartOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:orientation="vertical">

        <!--
            Contenedor del HUD de consumo. Empieza GONE si no hay MAC
            configurada; MainActivity lo hace VISIBLE al hacer bind al servicio.
            El fondo semitransparente va aquí para que el IndicatorView no
            necesite pintarlo él mismo (la View no pinta fondo propio).
        -->
        <FrameLayout
            android:id="@+id/hudContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:background="#CC101418"
            android:padding="8dp"
            android:visibility="gone">

            <obdmap.launcher.ui.IndicatorView
                android:id="@+id/hudFuelIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:label="@string/hud_fuel_label"
                app:unit="@string/hud_fuel_unit_l100km" />

        </FrameLayout>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#80000000"
            android:padding="10dp"
            android:text="@string/status_initializing"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

    </LinearLayout>

    <Button
        android:id="@+id/dayNightToggleButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="@color/surface_dark"
        android:minHeight="72dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/toggle_night_mode"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

    <!--
        Badge circular de velocidad GPS (esquina inferior izquierda, siempre visible).
        El recenterButton, al estar declarado después, se dibuja encima cuando es VISIBLE.
    -->
    <obdmap.launcher.ui.SpeedBadgeView
        android:id="@+id/speedBadge"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp" />

    <Button
        android:id="@+id/recenterButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="@color/primary"
        android:minHeight="72dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:text="@string/recenter_button"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:visibility="gone" />

    <!--
        Botón "Destino" centrado en la parte inferior.
        Es el único botón que queda en la barra inferior central tras eliminar
        "Ajustes OBD" y "Debug OBD" (que ahora viven dentro de la pantalla de Ajustes).
    -->
    <Button
        android:id="@+id/openDestinationButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/primary"
        android:minHeight="72dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:text="@string/open_destination_button"
        android:textColor="@color/text_primary"
        android:textSize="18sp" />

    <!--
        Panel de confirmación de destino por long-press (Fase 8).
        Aparece centrado en la parte inferior cuando el usuario hace long-press
        sobre el mapa. Por defecto GONE; se hace VISIBLE desde MainActivity.
        El minHeight grande garantiza zona táctil cómoda en el coche.
    -->
    <LinearLayout
        android:id="@+id/destConfirmPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:background="#CC101418"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/destConfirmText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="12dp"
            android:text="@string/dest_confirm_no_gps"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:orientation="horizontal">

            <Button
                android:id="@+id/destConfirmGoButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@color/primary"
                android:minHeight="72dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:text="@string/dest_confirm_go"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <Button
                android:id="@+id/destConfirmCancelButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/surface_dark"
                android:minHeight="72dp"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:text="@string/dest_confirm_cancel"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

        </LinearLayout>

    </LinearLayout>

    <!--
        Barra inferior de resumen de navegación: distancia restante + ETA.
        Solo visible cuando hay ruta activa.
        Se coloca centrada en la parte inferior, por encima del botón Destino.
    -->
    <LinearLayout
        android:id="@+id/navSummaryBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="100dp"
        android:background="#CC101418"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/navRemainingDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="·"
            android:textColor="#FFB0B0B0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/navEta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

    <!--
        Columna inferior derecha: botón de Ajustes de la app (encima) y el botón de
        emergencia hacia Ajustes del sistema (abajo). El LinearLayout los apila
        verticalmente con gravity bottom|end.
    -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:orientation="vertical">

        <!-- Botón "Ajustes" de la app: engloba la selección de ELM327 y el acceso al Debug OBD. -->
        <Button
            android:id="@+id/appSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@color/primary"
            android:minHeight="72dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:text="@string/app_settings_button"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <!-- Acceso de emergencia a los Ajustes del sistema. Siempre visible. -->
        <Button
            android:id="@+id/emergencyAccessButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/emergency_button"
            android:minHeight="72dp"
            android:paddingStart="28dp"
            android:paddingEnd="28dp"
            android:text="@string/emergency_access_button"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

    </LinearLayout>

</FrameLayout>
