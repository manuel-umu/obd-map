<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout principal del launcher. Estructura por capas (FrameLayout):
        1. MapView de Mapsforge ocupando todo el fondo.
        2. Overlay con texto de estado (esquina superior izquierda).
        3. Botón "Recentrar" (esquina inferior izquierda, oculto hasta pan manual).
        4. Botón de emergencia hacia Ajustes (esquina inferior derecha, siempre visible).
    El orden de los hijos en XML es importante: el último se dibuja por encima.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <org.mapsforge.map.android.view.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#80000000"
        android:padding="10dp"
        android:text="@string/status_initializing"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/recenterButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_margin="16dp"
        android:background="@color/primary"
        android:minHeight="56dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="@string/recenter_button"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/emergencyAccessButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:background="@color/emergency_button"
        android:minHeight="56dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="@string/emergency_access_button"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

</FrameLayout>
