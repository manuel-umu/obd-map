<?xml version="1.0" encoding="utf-8"?>
<!--
    Pantalla de Ajustes: menú de nivel superior. Solo botones de navegación.
    El detalle (Bluetooth OBD, debug, info) vive en sus propias pantallas.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_surface"
            android:minHeight="64dp"
            android:text="@string/back_button"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnBluetooth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_surface"
            android:minHeight="64dp"
            android:text="@string/settings_open_bluetooth"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnSystemSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_surface"
            android:minHeight="64dp"
            android:text="@string/settings_open_system"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnObdDebug"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:background="@drawable/btn_surface"
            android:minHeight="64dp"
            android:text="@string/settings_open_obd_debug"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_surface"
            android:minHeight="64dp"
            android:text="@string/settings_open_info"
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

    </LinearLayout>
</ScrollView>
