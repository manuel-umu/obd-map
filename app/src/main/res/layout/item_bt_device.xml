<?xml version="1.0" encoding="utf-8"?>
<!--
    Ítem individual de la lista de dispositivos Bluetooth emparejados.
    Muestra nombre y MAC en dos líneas. El fondo cambia vía selector
    de estado en código (setBackgroundColor) según esté seleccionado o no.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="64dp"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/deviceName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/deviceMac"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

</LinearLayout>
