<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Tema base: pantalla completa, sin barra de acción y fondo oscuro,
        pensado para que el mapa ocupe toda la pantalla.
    -->
    <style name="Theme.ObdMap" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.ObdMap.Day" parent="Theme.ObdMap">
        <item name="android:windowBackground">@color/background_day</item>
        <item name="android:textColorPrimary">@color/text_primary_day</item>
        <item name="android:textColorSecondary">@color/text_secondary_day</item>
    </style>
</resources>
