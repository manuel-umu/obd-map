<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Nombre visible de la aplicación. -->
    <string name="app_name">OBD-Map</string>

    <!-- Botones del layout principal. -->
    <string name="emergency_access_button">Ajustes del sistema</string>
    <string name="recenter_button">Recentrar</string>

    <!-- Botón que abre la pantalla de Ajustes de la app (esquina inferior derecha). -->
    <string name="open_app_settings_button">Ajustes OBD</string>
    <string name="app_settings_button">Ajustes</string>

    <!-- Botón dentro de la pantalla de Ajustes para acceder al Debug OBD. -->
    <string name="settings_open_obd_debug">Debug OBD</string>

    <!-- Pantalla de Ajustes — títulos y botones. -->
    <string name="settings_title">Ajustes — Adaptador OBD2</string>
    <string name="settings_section_paired">Dispositivos Bluetooth emparejados</string>
    <string name="settings_selected_label">Seleccionado: %1$s</string>
    <string name="settings_none_selected">Ninguno seleccionado</string>
    <string name="settings_clear_button">Borrar selección</string>
    <string name="settings_open_bt_settings">Abrir ajustes Bluetooth</string>

    <!-- Mensajes de estado dentro de Ajustes. -->
    <string name="settings_bt_off">Bluetooth apagado. Actívalo para buscar el adaptador ELM327.</string>
    <string name="settings_no_paired">No hay dispositivos emparejados. Pulsa «Buscar dispositivos» para escanear.</string>
    <string name="settings_no_bt_settings_app">No se encontró la app de Ajustes del sistema</string>

    <!-- Escaneo y emparejado desde la propia app. -->
    <string name="settings_scan_button">Buscar dispositivos</string>
    <string name="settings_scanning">Buscando…</string>
    <string name="settings_section_devices">Dispositivos Bluetooth</string>
    <string name="settings_badge_paired">Emparejado</string>
    <string name="settings_badge_unpaired">Sin emparejar</string>
    <string name="settings_bonding">Emparejando…</string>
    <string name="settings_bond_ok">%1$s emparejado y seleccionado como adaptador OBD2</string>
    <string name="settings_bond_fail">No se pudo emparejar con %1$s. Comprueba el PIN del adaptador.</string>
    <string name="settings_tap_to_pair">Toca el dispositivo para seleccionarlo o emparejarlo</string>

    <!-- Mensajes de estado (overlay superior izquierdo). -->
    <string name="status_initializing">Inicializando…</string>
    <string name="status_no_permissions">Permisos denegados — la app no puede funcionar</string>
    <string name="status_no_map">No se encontró archivo .map en /sdcard/Download</string>
    <string name="status_map_loaded">Mapa: %1$s · esperando GPS…</string>
    <string name="status_gps_active">GPS activo</string>
    <string name="status_gps_lost">GPS perdido</string>
    <!-- %1$d = porcentaje de descarga (0-100). -->
    <string name="status_downloading_map">Descargando mapa de Murcia… %1$d%%</string>
    <!-- %1$s = descripción breve del error. -->
    <string name="status_download_failed">No se pudo descargar el mapa: %1$s</string>

    <!-- Botón de acceso a la pantalla de debug OBD2 (Bloque C). -->
    <string name="open_obd_debug_button">Debug OBD</string>

    <!-- Estados del ObdService — usados en la notificación y en la pantalla de debug. -->
    <string name="obd_state_connecting">Conectando…</string>
    <string name="obd_state_initializing">Inicializando…</string>
    <string name="obd_state_connected">Conectado</string>
    <string name="obd_state_reconnecting">Reconectando…</string>
    <!-- Versión corta para la notificación cuando no hay descripción de error. -->
    <string name="obd_state_failed_short">Fallo de conexión</string>
    <!-- Versión larga con descripción; %1$s = mensaje de error del reader. -->
    <string name="obd_state_failed">Fallo: %1$s</string>
    <!-- Texto de la notificación cuando no hay MAC configurada. -->
    <string name="obd_notif_no_mac">Sin adaptador configurado</string>
    <!-- Estado en la pantalla de debug cuando no hay adaptador configurado. -->
    <string name="obd_state_no_mac">Sin adaptador OBD — selecciónalo en Ajustes</string>

    <!-- Pantalla de debug OBD2 (Bloque C, ítem 2.7). -->
    <string name="debug_title">Debug OBD2</string>
    <string name="debug_back_button">Atrás</string>
    <string name="debug_rpm_label">RPM:</string>
    <string name="debug_speed_label">Velocidad:</string>
    <string name="debug_speed_unit">km/h</string>
    <string name="debug_load_label">Carga motor:</string>
    <string name="debug_load_unit">%</string>
    <string name="debug_state_label">Estado:</string>
    <!-- %1$s = hora en formato HH:mm:ss -->
    <string name="debug_last_reading">Última lectura: %1$s</string>
    <string name="debug_no_reading_yet">Sin lecturas aún</string>
    <!-- Valor mostrado cuando el dato no ha llegado todavía. -->
    <string name="debug_no_data">—</string>

    <!-- Pantalla de debug OBD2 — Fase 3: telemetría de consumo diésel. -->
    <string name="debug_throttle_label">Acelerador:</string>
    <string name="debug_throttle_unit">%</string>
    <string name="debug_coolant_label">Refrig.:</string>
    <string name="debug_coolant_unit">°C</string>
    <string name="debug_iat_label">Adm. (IAT):</string>
    <string name="debug_iat_unit">°C</string>
    <string name="debug_map_label">MAP:</string>
    <string name="debug_map_unit">kPa</string>
    <string name="debug_fuelrate_label">Caudal (015E):</string>
    <string name="debug_fuelrate_unit">L/h</string>
    <string name="debug_fuelrate_unsupported">No soportado</string>
    <string name="debug_instant_lh_label">Consumo inst.:</string>
    <string name="debug_instant_lh_unit">L/h</string>
    <string name="debug_instant_l100km_label">Consumo inst.:</string>
    <string name="debug_instant_l100km_unit">L/100km</string>
    <string name="debug_average_l100km_label">Consumo medio:</string>
    <string name="debug_average_l100km_unit">L/100km</string>
    <string name="debug_fuel_method_label">Método consumo:</string>
    <string name="debug_fuel_method_none">Sin dato</string>
    <string name="debug_fuel_method_015e">015E (directo)</string>
    <string name="debug_fuel_method_maf">MAF (estimado)</string>
    <string name="debug_fuel_method_sd">Speed-Density</string>
    <string name="debug_reset_avg_button">Reiniciar medio</string>
    <!-- %1$.1f = valor float con 1 decimal -->
    <string name="debug_float_format">%1$.1f</string>

    <!-- Pantalla de destino (Fase 4, paso 4.3). -->
    <string name="title_destination">Fijar destino</string>
    <string name="hint_latitude">Latitud (ej: 37.9922)</string>
    <string name="hint_longitude">Longitud (ej: -1.1307)</string>
    <string name="btn_set_destination">Fijar destino</string>
    <string name="btn_cancel">Cancelar</string>
    <string name="btn_clear_destination">Borrar destino</string>
    <string name="toast_destination_set">Destino fijado</string>
    <string name="toast_destination_cleared">Destino borrado</string>
    <string name="toast_invalid_coordinates">Coordenadas no válidas</string>
    <!-- Botón en MainActivity para abrir la pantalla de destino. -->
    <string name="open_destination_button">Destino</string>

    <!-- Ruta calculada (paso 4.4). -->
    <!-- %1$s = distancia en km (p. ej. "12.3"), %2$s = tiempo en minutos (p. ej. "18"). -->
    <string name="route_summary">Ruta: %1$s km · %2$s min</string>
    <!-- Error genérico de routing mostrado en statusText. %1$s = mensaje de error. -->
    <string name="route_error">Error de ruta: %1$s</string>

    <!-- Aviso de voz TTS al confirmar el cálculo de una ruta (paso 5.4). -->
    <string name="voice_route_started">Ruta iniciada</string>

    <!-- Avisos de voz por proximidad a la maniobra (paso 5.5). -->
    <!-- Plantilla para avisos a 500 m y 200 m. %1$d = metros, %2$s = texto de la maniobra. -->
    <string name="voice_in_meters">En %1$d metros, %2$s</string>
    <!-- Plantilla para el aviso inminente a 50 m. %1$s = texto de la maniobra. -->
    <string name="voice_now">Ahora, %1$s</string>
    <!-- Se añade tras el texto de la maniobra cuando hay nombre de calle. %1$s = calle. -->
    <string name="voice_on_street">en %1$s</string>

    <!-- Textos de maniobra en español, indexados por el sign de GraphHopper. -->
    <string name="maneuver_turn_sharp_left">gire bruscamente a la izquierda</string>
    <string name="maneuver_turn_left">gire a la izquierda</string>
    <string name="maneuver_turn_slight_left">gírese ligeramente a la izquierda</string>
    <string name="maneuver_turn_slight_right">gírese ligeramente a la derecha</string>
    <string name="maneuver_turn_right">gire a la derecha</string>
    <string name="maneuver_turn_sharp_right">gire bruscamente a la derecha</string>
    <string name="maneuver_finish">ha llegado a su destino</string>
    <string name="maneuver_roundabout">tome la rotonda</string>
    <string name="maneuver_keep_left">manténgase a la izquierda</string>
    <string name="maneuver_keep_right">manténgase a la derecha</string>
    <string name="maneuver_uturn">haga un cambio de sentido</string>
    <string name="maneuver_continue">continúe recto</string>
    <string name="maneuver_generic">continúe</string>

    <!-- HUD de consumo en la pantalla principal (paso 3.5). -->
    <!-- Etiqueta del indicador de consumo instantáneo. -->
    <string name="hud_fuel_label">Consumo</string>
    <!-- Unidad cuando el coche supera el umbral de velocidad (L/100km). -->
    <string name="hud_fuel_unit_l100km">L/100km</string>
    <!-- Unidad cuando el coche está parado o muy lento (L/h). -->
    <string name="hud_fuel_unit_lh">L/h</string>
    <!-- %1$.1f = consumo con 1 decimal (p. ej. "7.3") -->
    <string name="hud_fuel_value_format">%1$.1f</string>

    <!-- Toggle modo día/noche en la pantalla principal. -->
    <string name="toggle_night_mode">Noche</string>
    <string name="toggle_day_mode">Día</string>

    <!-- Panel de confirmación de destino por long-press (Fase 8). -->
    <!-- Texto del panel cuando hay posición GPS y se puede calcular distancia en línea recta. -->
    <!-- %1$.1f = distancia con 1 decimal, %2$s = unidad (m o km). -->
    <string name="dest_confirm_distance">Destino a %1$.1f %2$s</string>
    <!-- Texto del panel cuando aún no hay posición GPS y no se puede calcular. -->
    <string name="dest_confirm_no_gps">Destino seleccionado</string>
    <!-- Botón para confirmar y calcular la ruta. -->
    <string name="dest_confirm_go">Ir</string>
    <!-- Botón para cancelar la selección del pin provisional. -->
    <string name="dest_confirm_cancel">Cancelar</string>
    <!-- Unidad metros, para distancias cortas. -->
    <string name="unit_meters">m</string>
    <!-- Unidad kilómetros, para distancias largas. -->
    <string name="unit_km">km</string>

    <!-- HUD de navegación (Fase 5.3). -->
    <!-- Descripción de accesibilidad del icono de maniobra. -->
    <string name="nav_maneuver_icon_desc">Icono de maniobra</string>
    <!-- Formato de distancia corta en metros (pasos de 10 o 50). %1$d = metros redondeados. -->
    <string name="nav_distance_meters">%1$d m</string>
    <!-- Formato de distancia larga en km con 1 decimal. %1$.1f = km. -->
    <string name="nav_distance_km">%1$.1f km</string>
    <!-- Hora estimada de llegada. %1$s = hora en formato HH:mm. -->
    <string name="nav_eta">Llegada: %1$s</string>
    <!-- Tiempo restante en minutos. %1$d = minutos. Usado junto a ETA. -->
    <string name="nav_time_remaining">%1$d min</string>
</resources>
