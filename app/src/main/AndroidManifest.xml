<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="obdmap.launcher">

    <!-- Comunicación con el ELM327 vía Bluetooth clásico (SPP). -->
    <uses-permission android:name="android.permission.BLUETOOTH" />
    <!-- Necesario para listar dispositivos emparejados desde la pantalla de Ajustes. -->
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" />

    <!-- GPS: la radio tiene receptor propio, accedemos vía LocationManager. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!-- Foreground Service para mantener la lectura OBD2 viva en segundo plano. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- WakeLock: evitar que la radio se duerma mientras se conduce. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Lectura de tarjeta SD para los mapas .map y los grafos .ghz. -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!--
        ÚNICA excepción a la filosofía offline: descarga puntual del mapa la
        primera vez que arranca la app sin ningún .map presente. En cuanto el
        mapa está en disco, la app no vuelve a necesitar red. INTERNET es un
        permiso "normal" (no runtime), así que no hay diálogo al usuario.
    -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        Necesario para ConnectivityManager.getActiveNetworkInfo() (el updater OTA
        comprueba si hay red antes de consultar GitHub). Sin este permiso, esa
        llamada lanza SecurityException y la app crashea al arrancar. Es un permiso
        "normal" (no runtime), sin diálogo al usuario.
    -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Auto-actualización OTA: permite lanzar la instalación del APK descargado.
        Obligatorio desde API 26 para instalar desde la propia app. El usuario debe
        conceder además "instalar apps de origen desconocido" a este launcher
        (ajuste del sistema, una vez).
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
        La app usa los iconos por defecto del sistema; cuando existan mipmaps
        propios se añadirán los atributos android:icon y android:roundIcon.
    -->
    <application
        android:name=".OBDMapApplication"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:label="@string/app_name"
        android:largeHeap="false"
        android:supportsRtl="false"
        android:theme="@style/Theme.ObdMap">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:keepScreenOn="true"
            android:launchMode="singleTask"
            android:screenOrientation="landscape"
            android:stateNotNeeded="true">

            <!-- Lanzador estándar: aparece en el cajón de apps. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Categoría HOME: permite seleccionar OBD-Map como launcher por defecto. -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Pantalla de Ajustes de la app (menú de nivel superior). -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Sub-pantalla de selección/emparejado del adaptador OBD por Bluetooth. -->
        <activity
            android:name=".ui.ObdBluetoothActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Pantalla de debug con la telemetría OBD2 en bruto. -->
        <activity
            android:name=".ui.ObdDebugActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Pantalla de Información: versión instalada y actualización OTA. -->
        <activity
            android:name=".ui.InfoActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!--
            Foreground Service que mantiene viva la conexión OBD2.
            FOREGROUND_SERVICE es obligatorio en targetSdk 28 (introducido en API 28).
            foregroundServiceType se omite: el atributo y el valor "connectedDevice"
            son API 29+; con targetSdk/compileSdk 28 el servicio funciona sin él.
            exported=false: solo se arranca desde dentro de la app.
        -->
        <service
            android:name=".service.ObdService"
            android:exported="false" />

        <!-- Pantalla de introducción manual del destino de ruta. -->
        <activity
            android:name=".ui.DestinationActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!--
            FileProvider del auto-updater OTA: expone el APK descargado
            al instalador del sistema con un content:// URI. Obligatorio en API 24+
            (un file:// lanzaría FileUriExposedException). La authority usa
            ${applicationId} para no colisionar con otras apps.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
